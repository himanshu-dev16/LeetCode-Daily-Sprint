class Solution:
    def intersect(self, nums1: list[int], nums2: list[int]) -> list[int]:
        counts = {}
        for num in nums1:
            counts[num] = counts.get(num, 0) + 1
            
        result = []
        
        for num in nums2:
            if num in counts and counts[num] > 0:
                result.append(num)
                counts[num] -= 1 
                
        return result
