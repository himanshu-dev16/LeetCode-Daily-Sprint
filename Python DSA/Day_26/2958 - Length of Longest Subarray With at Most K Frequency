class Solution:
    def maxSubarrayLength(self, nums: list[int], k: int) -> int:
        count = {}
        left = max_len = 0
        
        for right in range(len(nums)):
            count[nums[right]] = count.get(nums[right], 0) + 1
            
            while count[nums[right]] > k:
                count[nums[left]] -= 1
                left += 1
                
            max_len = max(max_len, right - left + 1)
            
        return max_len
