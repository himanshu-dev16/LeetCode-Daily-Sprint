WITH CTE AS (
    SELECT id, visit_date, people,
           LAG(people, 2) OVER (ORDER BY id) AS prev2,
           LAG(people, 1) OVER (ORDER BY id) AS prev1,
           LEAD(people, 1) OVER (ORDER BY id) AS next1,
           LEAD(people, 2) OVER (ORDER BY id) AS next2
    FROM Stadium
)
SELECT id, visit_date, people
FROM CTE
WHERE people >= 100 AND (
    (prev2 >= 100 AND prev1 >= 100) OR -- Yeh aakhiri row hai
    (prev1 >= 100 AND next1 >= 100) OR -- Yeh beech ki row hai
    (next1 >= 100 AND next2 >= 100)    -- Yeh shuruat ki row hai
)
ORDER BY visit_date;
